# ═══════════════════════════════════════════════════════════════
# Craft Cafe - Environment Variables
# Copy this to .env and fill in your real values
# NEVER commit .env to git!
# ═══════════════════════════════════════════════════════════════

# ── SECURITY (REQUIRED) ─────────────────────────────────────────
SECRET_KEY=generate-a-secure-random-key-here-min-50-chars
DEBUG=False

# ── HTTPS SETTINGS (Production) ──────────────────────────────
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ── DATABASE ───────────────────────────────────────────────────────
DB_NAME=cafe_db
DB_USER=postgres
DB_PASSWORD=your-secure-password-here
DB_HOST=localhost
DB_PORT=5432
DB_SSL_MODE=prefer

# ── REDIS CACHE (Optional) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── EMAIL: Gmail SMTP ────────────────────────────────────────────
# 1. Enable 2FA on your Google account
# 2. Go to Google Account > Security > App Passwords
# 3. Generate an App Password for "Mail"
# 4. Paste it below (NOT your regular Gmail password)

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
DEFAULT_FROM_EMAIL=Craft Cafe <your-gmail@gmail.com>
ADMIN_EMAIL=admin@yourdomain.com

# ── Email: SendGrid (Alternative - better for production) ─────────���─
# EMAIL_BACKEND=sendgrid_backend.SendgridBackend
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# ── Development: Print emails to terminal ────────────────────
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ── RATE LIMITING ────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ── LOGGING ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs

# ── PRODUCTION ONLY ─────────────────────────────────────────────
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── OPTIONAL: SENTRY ERROR TRACKING ─────────────────────────────
# Get free tier at https://sentry.io
# SENTRY_DSN=https://key@sentry.io/project
